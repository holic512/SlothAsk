<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.servicegateway.requestlog.mapper.AdminRequestLogMapper">

    <insert id="insertAdminRequestLogs">
        INSERT INTO admin_request_log (admin_id, request_time, request_path)
        VALUES
        <foreach collection="list" item="log" separator=",">
            (#{log.adminId}, #{log.requestTime}, #{log.requestPath})
        </foreach>
    </insert>

</mapper>
